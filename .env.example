PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d
JWT_REMEMBER_EXPIRES_IN=30d
DATABASE_PATH=./data/jarcade.db

# Comma-separated allowed frontend origins (required for browser requests)
# Local dev + your deployed site, e.g.:
# CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,https://michealshodipo56.github.io,https://your-custom-domain.com
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080,http://127.0.0.1:8080

# Render: attach a persistent disk at /var/data and set:
# DATABASE_PATH=/var/data/jarcade.db
