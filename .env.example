PORT=8080
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# REQUIRED — direct Postgres connection (recommended for Go on Render)
#
# Where to find it in Supabase:
#   1. Open your project → Project Settings (gear) → Database
#   2. Under "Connection string", choose URI
#   3. Select "Transaction" pooler (port 6543) — best for serverless/Render
#   4. Copy the string and replace [YOUR-PASSWORD] with your database password
#
# Example shape:
# DATABASE_URL=postgresql://postgres.abcdefghijklmnop:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080,http://127.0.0.1:8080

# --- Optional fallback (only if you do NOT set DATABASE_URL) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=   # secret — never use the publishable/anon key here
