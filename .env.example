PORT=8080
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# REQUIRED — Postgres connection via Supabase POOLER (not direct db.* host)
#
# ⚠️  Do NOT use db.xxxx.supabase.co:5432 — Render cannot reach it (IPv6).
# ✅  Use the Transaction pooler on port 6543:
#
#   1. Supabase → Project Settings → Database
#   2. Connection string → URI → Method: "Transaction pooler"
#   3. Copy and replace [YOUR-PASSWORD] with your database password
#
# Example (note pooler.supabase.com and port 6543):
# DATABASE_URL=postgresql://postgres.abcdefghijklmnop:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Comma-separated allowed frontend origins (exact URLs, no trailing slash)
CORS_ORIGIN=https://jarcade.vercel.app,http://localhost:5500,http://127.0.0.1:5500

# Password reset (until email SMTP is added, expose link in API response for testing)
FRONTEND_URL=https://jarcade.vercel.app
EXPOSE_PASSWORD_RESET_LINK=true

# Optional Google OAuth (same client ID as frontend JARCADE_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=

# --- Optional fallback (only if you do NOT set DATABASE_URL) ---
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=   # secret — never use the publishable/anon key here
