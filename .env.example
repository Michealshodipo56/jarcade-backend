PORT=8080
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# Supabase project URL (https://xxxx.supabase.co)
SUPABASE_URL=

# Service role key — server only, never expose to the frontend
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres connection (recommended for Go on Render).
# Supabase → Project Settings → Database → Connection string (pooler, port 6543)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Comma-separated allowed frontend origins
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://localhost:8080,http://127.0.0.1:8080
